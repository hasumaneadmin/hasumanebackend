{
  "title": "HasuMane SaaS Backend",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["hasumane", "nestjs", "saas"],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "API Requests",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "increase(hasumane_api_requests_total[5m])" }]
    },
    {
      "type": "stat",
      "title": "API Errors",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "increase(hasumane_api_errors_total[5m])" }]
    },
    {
      "type": "gauge",
      "title": "Average Latency",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "hasumane_api_request_duration_average_ms" }],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "type": "stat",
      "title": "Active Users",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "hasumane_api_active_users" }]
    },
    {
      "type": "timeseries",
      "title": "Request and Error Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "rate(hasumane_api_requests_total[5m])", "legendFormat": "requests/sec" },
        { "expr": "rate(hasumane_api_errors_total[5m])", "legendFormat": "errors/sec" }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU and Memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "hasumane_api_cpu_usage_percent", "legendFormat": "cpu %" },
        { "expr": "hasumane_api_memory_heap_used_bytes", "legendFormat": "heap bytes" },
        { "expr": "hasumane_api_memory_rss_bytes", "legendFormat": "rss bytes" }
      ]
    },
    {
      "type": "stat",
      "title": "Database Queries",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 12 },
      "targets": [{ "expr": "increase(hasumane_api_database_queries_total[5m])" }]
    },
    {
      "type": "stat",
      "title": "Low Inventory",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 12 },
      "targets": [{ "expr": "hasumane_api_low_inventory_items" }]
    },
    {
      "type": "stat",
      "title": "Process Uptime",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 12 },
      "targets": [{ "expr": "hasumane_api_uptime_seconds" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
