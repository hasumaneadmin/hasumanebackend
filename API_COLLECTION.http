@baseUrl = http://localhost:5000/api/v1
@accessToken = paste-access-token-here
@refreshToken = paste-refresh-token-here
@csrfToken = paste-csrf-token-here
@productId = paste-product-id-here
@categoryId = paste-category-id-here
@inventoryItemId = paste-inventory-item-id-here
@orderId = paste-order-id-here
@cartItemId = paste-cart-item-id-here
@notificationId = paste-notification-id-here
@emailToken = paste-email-token-here
@resetToken = paste-reset-token-here

### Health
GET {{baseUrl}}/health

### Auth: register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Demo Customer",
  "email": "customer@example.com",
  "phone": "+919876543210",
  "password": "ChangeMe@12345",
  "role": "CUSTOMER"
}

### Auth: login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "superadmin@hasumane.local",
  "password": "ChangeMe@12345"
}

### Auth: refresh
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Auth: logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}

### Auth: profile
GET {{baseUrl}}/auth/profile
Authorization: Bearer {{accessToken}}

### Auth: update profile
PUT {{baseUrl}}/auth/profile
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "name": "Updated Customer"
}

### Auth: forgot password
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "customer@example.com"
}

### Auth: reset password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "password": "NewChangeMe@12345"
}

### Auth: verify email
POST {{baseUrl}}/auth/verify-email
Content-Type: application/json

{
  "token": "{{emailToken}}"
}

### Auth: resend verification
POST {{baseUrl}}/auth/resend-verification
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}

### Products: list
GET {{baseUrl}}/products?page=1&limit=20

### Products: get by id
GET {{baseUrl}}/products/{{productId}}

### Products: create
POST {{baseUrl}}/products
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "code": "MILK-001",
  "name": "A2 Cow Milk",
  "productType": "a2_cow_milk",
  "unit": "liter",
  "price": 90,
  "defaultQuantity": 1,
  "defaultSchedule": "daily",
  "isActive": true
}

### Products: update
PUT {{baseUrl}}/products/{{productId}}
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "price": 95,
  "description": "Fresh A2 cow milk."
}

### Products: delete
DELETE {{baseUrl}}/products/{{productId}}
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}

### Categories: list
GET {{baseUrl}}/categories

### Categories: create
POST {{baseUrl}}/categories
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "name": "Milk",
  "slug": "milk",
  "description": "Fresh dairy products",
  "isActive": true
}

### Categories: update
PUT {{baseUrl}}/categories/{{categoryId}}
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "sortOrder": 10
}

### Categories: delete
DELETE {{baseUrl}}/categories/{{categoryId}}
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}

### Products: search
GET {{baseUrl}}/products/search?search=milk&page=1&limit=20

### Orders: create from cart
POST {{baseUrl}}/orders
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "shippingFee": 20,
  "discount": 0,
  "currency": "INR"
}

### Orders: list
GET {{baseUrl}}/orders?page=1&limit=20
Authorization: Bearer {{accessToken}}

### Orders: get by id
GET {{baseUrl}}/orders/{{orderId}}
Authorization: Bearer {{accessToken}}

### Orders: cancel
PUT {{baseUrl}}/orders/{{orderId}}/cancel
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}

### Cart: get
GET {{baseUrl}}/cart
Authorization: Bearer {{accessToken}}

### Cart: add item
POST {{baseUrl}}/cart/add
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "productId": "{{productId}}",
  "quantity": 2
}

### Cart: update item
PUT {{baseUrl}}/cart/update
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "itemId": "{{cartItemId}}",
  "quantity": 3
}

### Cart: remove item
DELETE {{baseUrl}}/cart/remove
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "itemId": "{{cartItemId}}"
}

### Admin: dashboard
GET {{baseUrl}}/admin/dashboard
Authorization: Bearer {{accessToken}}

### Admin: users
GET {{baseUrl}}/admin/users?page=1&limit=20
Authorization: Bearer {{accessToken}}

### Admin: orders
GET {{baseUrl}}/admin/orders?page=1&limit=20
Authorization: Bearer {{accessToken}}

### Admin: products
GET {{baseUrl}}/admin/products?page=1&limit=20
Authorization: Bearer {{accessToken}}

### Admin: create product
POST {{baseUrl}}/admin/products
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "code": "CURD-001",
  "name": "Farm Curd",
  "productType": "farm_curd",
  "unit": "kg",
  "price": 120,
  "defaultQuantity": 1,
  "defaultSchedule": "daily",
  "isActive": true
}

### Admin: update product
PUT {{baseUrl}}/admin/products/{{productId}}
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "isActive": true,
  "price": 125
}

### Admin: delete product
DELETE {{baseUrl}}/admin/products/{{productId}}
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}

### Admin: reports
GET {{baseUrl}}/admin/reports
Authorization: Bearer {{accessToken}}

### Admin: analytics
GET {{baseUrl}}/admin/analytics
Authorization: Bearer {{accessToken}}

### Admin: logs
GET {{baseUrl}}/admin/logs?page=1&limit=20
Authorization: Bearer {{accessToken}}

### Audit logs: list
GET {{baseUrl}}/audit-logs?page=1&limit=20&action=create
Authorization: Bearer {{accessToken}}

### Audit logs: dashboard
GET {{baseUrl}}/audit-logs/dashboard
Authorization: Bearer {{accessToken}}

### Structured logs
GET {{baseUrl}}/logs?page=1&limit=20&severity=error&module=auth
Authorization: Bearer {{accessToken}}

### Analytics: overview
GET {{baseUrl}}/analytics/overview?period=monthly
Authorization: Bearer {{accessToken}}

### Analytics: orders CSV export
GET {{baseUrl}}/analytics/orders?period=weekly&format=csv
Authorization: Bearer {{accessToken}}

### Analytics: subscriptions
GET {{baseUrl}}/analytics/subscriptions?period=monthly
Authorization: Bearer {{accessToken}}

### Analytics: leads
GET {{baseUrl}}/analytics/leads?period=monthly
Authorization: Bearer {{accessToken}}

### Analytics: inventory
GET {{baseUrl}}/analytics/inventory
Authorization: Bearer {{accessToken}}

### Analytics: notifications PDF export
GET {{baseUrl}}/analytics/notifications?period=monthly&format=pdf
Authorization: Bearer {{accessToken}}

### Inventory: list
GET {{baseUrl}}/inventory
Authorization: Bearer {{accessToken}}

### Inventory: low stock
GET {{baseUrl}}/inventory/low-stock
Authorization: Bearer {{accessToken}}

### Inventory: out of stock
GET {{baseUrl}}/inventory/out-of-stock
Authorization: Bearer {{accessToken}}

### Inventory: movements
GET {{baseUrl}}/inventory/movements
Authorization: Bearer {{accessToken}}

### Inventory: adjust stock
PATCH {{baseUrl}}/inventory/{{inventoryItemId}}/adjust
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}
Content-Type: application/json

{
  "movementType": "adjustment",
  "quantity": 25,
  "reason": "Cycle count correction"
}

### Notification center: pending
GET {{baseUrl}}/notification-center/pending
Authorization: Bearer {{accessToken}}

### Notification center: sent
GET {{baseUrl}}/notification-center/sent
Authorization: Bearer {{accessToken}}

### Notification center: failed
GET {{baseUrl}}/notification-center/failed
Authorization: Bearer {{accessToken}}

### Notification center: retry
POST {{baseUrl}}/notification-center/{{notificationId}}/retry
Authorization: Bearer {{accessToken}}
x-csrf-token: {{csrfToken}}

### Metrics
GET {{baseUrl}}/metrics
