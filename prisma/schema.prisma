datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String               @id @default(uuid())
  name                String
  phone               String               @unique
  email               String?              @unique
  passwordHash        String?              @map("password_hash")
  emailVerifiedAt     DateTime?            @map("email_verified_at")
  twoFactorEnabled    Boolean              @default(false) @map("two_factor_enabled")
  twoFactorSecret     String?              @map("two_factor_secret")
  role                String // "CUSTOMER" | "DELIVERY_PARTNER" | "SUPPORT" | "MANAGER" | "ADMIN" | "SUPER_ADMIN"
  isBlocked           Boolean              @default(false) @map("is_blocked")
  lastLoginAt         DateTime?            @map("last_login_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  deletedAt           DateTime?            @map("deleted_at")
  createdBy           String?              @map("created_by")
  updatedBy           String?              @map("updated_by")
  addresses           Address[]
  carts               Cart[]
  wishlistItems       WishlistItem[]
  orders              Order[]
  deliveryAssignments DeliveryAssignment[]
  subscriptions       Subscription[]
  sessions            UserSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  milkProcurementLogs MilkProcurementLog[]
  deliveryPartnerProfile DeliveryPartnerProfile?

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model UserSession {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash    String    @map("refresh_token_hash")
  csrfTokenHash       String?   @map("csrf_token_hash")
  ipAddress           String?   @map("ip_address")
  userAgent           String?   @map("user_agent")
  expiresAt           DateTime  @map("expires_at")
  revokedAt           DateTime? @map("revoked_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  createdBy           String?   @map("created_by")
  updatedBy           String?   @map("updated_by")

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model EmailVerificationToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model Address {
  id            String  @id @default(uuid())
  userId        String  @map("user_id")
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  streetAddress String  @map("street_address")
  pincode       String
  latitude      Decimal
  longitude     Decimal
  isActive      Boolean @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  createdBy     String? @map("created_by")
  updatedBy     String? @map("updated_by")

  @@map("addresses")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String     @default("active")
  items     CartItem[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")
  createdBy String?    @map("created_by")
  updatedBy String?    @map("updated_by")

  @@index([userId])
  @@index([status])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String   @map("cart_id")
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String?  @map("product_id")
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?  @map("variant_id")
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity  Decimal  @default(1)
  unitPrice Decimal? @map("unit_price")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String?  @map("product_id")
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

model Subscription {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  productType  String       @map("product_type") // e.g. whole_milk, curd, ghee
  quantity     Int
  scheduleType String       @map("schedule_type") // daily | alternate | custom
  customDays   Json?        @map("custom_days") // e.g. ["Mon","Wed","Fri"]
  status       String       @default("active") // active | paused | terminated
  startDate    DateTime     @default(now()) @map("start_date")
  pauseUntil   DateTime?    @map("pause_until")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  createdBy    String?      @map("created_by")
  updatedBy    String?      @map("updated_by")
  dailyOrders  DailyOrder[]

  @@map("subscriptions")
}

model Lead {
  id             String   @id @default(uuid())
  userId         String?  @map("user_id")
  subscriptionId String?  @map("subscription_id")
  name           String
  phone          String
  area           String
  productType    String   @map("product_type")
  quantity       Int
  scheduleType   String   @map("schedule_type")
  notes          String?
  source         String?
  status         String   @default("new")
  userAgent      String?  @map("user_agent")
  referrer       String?
  submittedAt    DateTime @default(now()) @map("submitted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([phone])
  @@index([status])
  @@index([submittedAt])
  @@map("leads")
}

model Order {
  id          String   @id @default(uuid())
  orderNumber String   @unique @map("order_number")
  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  status      String   @default("pending")
  subtotal    Decimal  @default(0)
  taxAmount   Decimal  @default(0) @map("tax_amount")
  shippingFee Decimal  @default(0) @map("shipping_fee")
  discount    Decimal  @default(0)
  total       Decimal  @default(0)
  currency    String   @default("INR")
  items       OrderItem[]
  statusHistory OrderStatusHistory[]
  payments    Payment[]
  refunds     RefundRequest[]
  deliveryAssignments DeliveryAssignment[]
  trackingLogs TrackingLog[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?  @map("created_by")
  updatedBy   String?  @map("updated_by")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?  @map("product_id")
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId   String?  @map("variant_id")
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  sku         String?
  name        String
  quantity    Decimal
  unitPrice   Decimal  @map("unit_price")
  taxAmount   Decimal  @default(0) @map("tax_amount")
  total       Decimal
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  note      String?
  changedBy String?  @map("changed_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_status_history")
}

model Product {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  productType     String   @unique @map("product_type")
  categoryId      String?  @map("category_id")
  category        ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit            String   @default("unit")
  price           Decimal? @map("price")
  compareAtPrice  Decimal? @map("compare_at_price")
  taxPercent      Decimal? @map("tax_percent")
  defaultQuantity Int      @default(1) @map("default_quantity")
  defaultSchedule String   @default("daily") @map("default_schedule")
  description     String?
  tags            Json?
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  createdBy       String?  @map("created_by")
  updatedBy       String?  @map("updated_by")
  images          ProductImage[]
  variants        ProductVariant[]
  inventoryItems  InventoryItem[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  orderItems      OrderItem[]

  @@index([categoryId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("products")
}

model ProductCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?   @map("image_url")
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by")
  updatedBy   String?   @map("updated_by")
  products    Product[]

  @@index([isActive])
  @@map("product_categories")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id             String   @id @default(uuid())
  productId      String   @map("product_id")
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku            String   @unique
  name           String
  unit           String   @default("unit")
  price          Decimal?
  compareAtPrice Decimal? @map("compare_at_price")
  attributes     Json?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?  @map("created_by")
  updatedBy      String?  @map("updated_by")
  inventoryItems InventoryItem[]
  cartItems      CartItem[]
  orderItems     OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model InventoryItem {
  id            String   @id @default(uuid())
  productId     String?  @map("product_id")
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId     String?  @map("variant_id")
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  sku           String?
  currentStock  Decimal  @default(0) @map("current_stock")
  reservedStock Decimal  @default(0) @map("reserved_stock")
  reorderLevel  Decimal  @default(0) @map("reorder_level")
  unit          String   @default("unit")
  warehouseName String?  @map("warehouse_name")
  status        String   @default("in_stock")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  createdBy     String?  @map("created_by")
  updatedBy     String?  @map("updated_by")
  movements     StockMovement[]

  @@index([productId])
  @@index([variantId])
  @@map("inventory_items")
}

model StockMovement {
  id              String   @id @default(uuid())
  inventoryItemId String   @map("inventory_item_id")
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  movementType    String   @map("movement_type")
  quantity        Decimal
  reason          String?
  referenceType   String?  @map("reference_type")
  referenceId     String?  @map("reference_id")
  createdById     String?  @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  updatedBy       String?  @map("updated_by")

  @@index([inventoryItemId])
  @@map("stock_movements")
}

model Supplier {
  id             String   @id @default(uuid())
  name           String
  phone          String?
  email          String?
  address        String?
  gstNumber      String?  @map("gst_number")
  contactPerson  String?  @map("contact_person")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("suppliers")
}

model PurchaseRecord {
  id            String   @id @default(uuid())
  supplierId    String?  @map("supplier_id")
  productId     String?  @map("product_id")
  variantId     String?  @map("variant_id")
  quantity      Decimal
  unit          String   @default("unit")
  unitCost      Decimal  @map("unit_cost")
  totalCost     Decimal  @map("total_cost")
  invoiceNumber String?  @map("invoice_number")
  purchaseDate  DateTime @default(now()) @map("purchase_date")
  status        String   @default("received")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([supplierId])
  @@index([productId])
  @@map("purchase_records")
}

model Coupon {
  id                String   @id @default(uuid())
  code              String   @unique
  title             String
  description       String?
  discountType      String   @map("discount_type")
  discountValue     Decimal  @map("discount_value")
  minOrderAmount    Decimal? @map("min_order_amount")
  maxDiscountAmount Decimal? @map("max_discount_amount")
  startsAt          DateTime? @map("starts_at")
  endsAt            DateTime? @map("ends_at")
  usageLimit        Int?     @map("usage_limit")
  usedCount         Int      @default(0) @map("used_count")
  status            String   @default("draft")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  createdBy         String?  @map("created_by")
  updatedBy         String?  @map("updated_by")
  usage             CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String   @map("coupon_id")
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String?  @map("user_id")
  orderId   String?  @map("order_id")
  discount  Decimal  @default(0)
  usedAt    DateTime @default(now()) @map("used_at")

  @@index([couponId])
  @@index([userId])
  @@map("coupon_usage")
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String?  @map("order_id")
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  userId        String?  @map("user_id")
  gateway       String?
  paymentMethod String?  @map("payment_method")
  amount        Decimal
  currency      String   @default("INR")
  status        String   @default("pending")
  transactionId String?  @map("transaction_id")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  createdBy     String?  @map("created_by")
  updatedBy     String?  @map("updated_by")
  transactions  Transaction[]

  @@index([orderId])
  @@index([userId])
  @@map("payments")
}

model Transaction {
  id             String   @id @default(uuid())
  paymentId      String?  @map("payment_id")
  payment        Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  gateway        String
  gatewayRef     String?  @map("gateway_ref")
  amount         Decimal
  currency       String   @default("INR")
  status         String
  rawPayload     Json?    @map("raw_payload")
  processedAt    DateTime? @map("processed_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([paymentId])
  @@index([gatewayRef])
  @@map("transactions")
}

model RefundRequest {
  id          String   @id @default(uuid())
  paymentId   String?  @map("payment_id")
  orderId     String?  @map("order_id")
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  userId      String?  @map("user_id")
  amount      Decimal
  reason      String?
  status      String   @default("requested")
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?  @map("created_by")
  updatedBy   String?  @map("updated_by")

  @@index([paymentId])
  @@index([orderId])
  @@map("refund_requests")
}

model SettlementReport {
  id          String   @id @default(uuid())
  partnerId   String?  @map("partner_id")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  grossAmount Decimal  @map("gross_amount")
  deductions  Decimal  @default(0)
  netAmount   Decimal  @map("net_amount")
  status      String   @default("pending")
  paidAt      DateTime? @map("paid_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([partnerId])
  @@map("settlement_reports")
}

model SupportTicket {
  id           String   @id @default(uuid())
  customerId   String?  @map("customer_id")
  assignedToId String?  @map("assigned_to_id")
  subject      String
  category     String?
  priority     String   @default("medium")
  status       String   @default("open")
  message      String
  resolution   String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([assignedToId])
  @@map("support_tickets")
}

model ContentBlock {
  id          String   @id @default(uuid())
  contentType String   @map("content_type")
  title       String
  slug        String   @unique
  body        String?
  imageUrl    String?  @map("image_url")
  ctaLabel    String?  @map("cta_label")
  ctaUrl      String?  @map("cta_url")
  isPublished Boolean  @default(false) @map("is_published")
  sortOrder   Int      @default(0) @map("sort_order")
  startsAt    DateTime? @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([contentType])
  @@map("content_blocks")
}

model Banner {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String   @map("image_url")
  targetUrl   String?  @map("target_url")
  placement   String   @default("home")
  isActive    Boolean  @default(true) @map("is_active")
  startsAt    DateTime? @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?  @map("created_by")
  updatedBy   String?  @map("updated_by")

  @@index([placement])
  @@map("banners")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  channel     String   @default("in_app")
  type        String
  title       String?
  body        String
  status      String   @default("queued")
  metadata    Json?
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([userId])
  @@index([status])
  @@map("notifications")
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  userId    String?  @map("user_id")
  sessionId String?  @map("session_id")
  referrer  String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([path])
  @@index([createdAt])
  @@map("page_views")
}

model SalesReport {
  id          String   @id @default(uuid())
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  grossRevenue Decimal @default(0) @map("gross_revenue")
  netRevenue   Decimal @default(0) @map("net_revenue")
  orderCount   Int     @default(0) @map("order_count")
  refundAmount Decimal @default(0) @map("refund_amount")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([periodStart, periodEnd])
  @@map("sales_reports")
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  module    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([module])
  @@map("user_activity")
}

model DeliveryPartnerProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verificationStatus String   @default("pending") @map("verification_status")
  vehicleType        String?  @map("vehicle_type")
  vehicleNumber      String?  @map("vehicle_number")
  licenseNumber      String?  @map("license_number")
  currentLatitude    Decimal? @map("current_latitude")
  currentLongitude   Decimal? @map("current_longitude")
  isAvailable        Boolean  @default(true) @map("is_available")
  rating             Decimal  @default(0)
  totalDeliveries    Int      @default(0) @map("total_deliveries")
  earningsBalance    Decimal  @default(0) @map("earnings_balance")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("delivery_partner_profiles")
}

model DeliveryZone {
  id          String   @id @default(uuid())
  name        String
  pincode     String
  city        String?
  state       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([pincode])
  @@map("delivery_zones")
}

model DeliveryAssignment {
  id                String   @id @default(uuid())
  orderId           String?  @map("order_id")
  order             Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  deliveryPartnerId String?  @map("delivery_partner_id")
  deliveryPartner   User?    @relation(fields: [deliveryPartnerId], references: [id], onDelete: SetNull)
  status            String   @default("assigned")
  assignedAt        DateTime @default(now()) @map("assigned_at")
  completedAt       DateTime? @map("completed_at")
  proofPhotoUrl     String?  @map("proof_photo_url")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  createdBy         String?  @map("created_by")
  updatedBy         String?  @map("updated_by")

  @@index([orderId])
  @@index([deliveryPartnerId])
  @@index([status])
  @@map("delivery_assignments")
}

model TrackingLog {
  id          String   @id @default(uuid())
  orderId     String?  @map("order_id")
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  actorId     String?  @map("actor_id")
  status      String
  latitude    Decimal?
  longitude   Decimal?
  message     String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([actorId])
  @@map("tracking_logs")
}

model RolePermission {
  id        String   @id @default(uuid())
  role      String
  module    String
  canView   Boolean  @default(true) @map("can_view")
  canCreate Boolean  @default(false) @map("can_create")
  canEdit   Boolean  @default(false) @map("can_edit")
  canDelete Boolean  @default(false) @map("can_delete")
  canExport Boolean  @default(false) @map("can_export")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([role, module])
  @@map("role_permissions")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  actorId    String?  @map("actor_id")
  action     String
  module     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([actorId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemLog {
  id         String   @id @default(uuid())
  level      String
  category   String
  module     String
  message    String
  requestId  String?  @map("request_id")
  userId     String?  @map("user_id")
  endpoint   String?
  method     String?
  statusCode Int?     @map("status_code")
  durationMs Int?     @map("duration_ms")
  errorStack String?  @map("error_stack")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([level])
  @@index([category])
  @@index([module])
  @@index([userId])
  @@index([createdAt])
  @@map("system_logs")
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  role      String?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  status    String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("login_history")
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  prefix      String   @unique
  secretHash  String   @map("secret_hash")
  permissions Json?
  status      String   @default("active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("api_keys")
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  group     String
  label     String
  value     Json
  isSecret  Boolean  @default(false) @map("is_secret")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("app_settings")
}

model DailyOrder {
  id             String       @id @default(uuid())
  subscriptionId String       @map("subscription_id")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  deliveryDate   DateTime     @map("delivery_date")
  quantity       Int
  status         String       @default("pending") // pending | delivered | failed
  riderId        String?      @map("rider_id")
  deliveredAt    DateTime?    @map("delivered_at")
  proofPhotoUrl  String?      @map("proof_photo_url")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  createdBy      String?      @map("created_by")
  updatedBy      String?      @map("updated_by")

  @@index([status])
  @@index([deliveryDate])
  @@map("daily_orders")
}

model MilkProcurementLog {
  id             String   @id @default(uuid())
  farmerId       String   @map("farmer_id")
  farmer         User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  collectionDate DateTime @map("collection_date")
  quantityLiters Decimal  @map("quantity_liters")
  fatPercentage  Decimal  @map("fat_percentage")
  snfPercentage  Decimal  @map("snf_percentage")
  ratePerLiter   Decimal  @map("rate_per_liter")
  totalPayout    Decimal  @map("total_payout")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  createdBy       String?  @map("created_by")
  updatedBy       String?  @map("updated_by")

  @@map("milk_procurement_logs")
}
