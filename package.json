{
  "name": "hasumane-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "backend/services/auth",
    "backend/services/subscription",
    "backend/services/dispatch",
    "backend/services/notification",
    "backend/services/procurement"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:auth": "npm run start --workspace=backend/services/auth",
    "dev:subscription": "npm run start --workspace=backend/services/subscription",
    "dev:dispatch": "npm run start --workspace=backend/services/dispatch",
    "dev:notification": "npm run start --workspace=backend/services/notification",
    "dev:procurement": "npm run start --workspace=backend/services/procurement",
    "dev": "npx concurrently -n \"front,auth,sub,disp,notif,proc\" -c \"cyan,magenta,yellow,blue,green,white\" \"npm run dev:frontend\" \"npm run dev:auth\" \"npm run dev:subscription\" \"npm run dev:dispatch\" \"npm run dev:notification\" \"npm run dev:procurement\"",
    "build": "npm run build --workspace=frontend",
    "build:dev": "npm run build:dev --workspace=frontend",
    "preview": "npm run preview --workspace=frontend",
    "start": "npm run start --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
