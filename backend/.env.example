PORT=5000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hasumane
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-64-char-access-secret
JWT_REFRESH_SECRET=replace-with-64-char-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_SECRET=replace-with-cookie-signing-secret
CSRF_HEADER=x-csrf-token
PASSWORD_HASH_ROUNDS=12
ADMIN_2FA_ISSUER=HasuMane Admin

ADMIN_API_TOKEN=sujan
ADMIN_EMAIL=admin@hasumane.local
ADMIN_PHONE=+919345340095

# Optional: enable real Postgres through Prisma.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Optional: enable live WhatsApp provider instead of simulated notifications.
# WATI_API_KEY=
